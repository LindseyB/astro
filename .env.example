# Copy this file to .env and fill in your own values:
#   cp .env.example .env        (macOS/Linux)
#   Copy-Item .env.example .env (Windows PowerShell)
#
# .env is git-ignored, so your real keys stay out of version control.
# The app loads these automatically on startup (via python-dotenv).

# Required: Secret key used to sign Flask sessions. Use a long, random value.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret

# Required: Anthropic API key used for the AI horoscope analysis.
# Get one at https://console.anthropic.com/
ANTHROPIC_TOKEN=your-anthropic-key-here

# Optional: Last.fm API key for music suggestions. Leave blank to disable.
LAST_FM_API_KEY=
